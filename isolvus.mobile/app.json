{
  "expo": {
    "name": "ISOLVUS Mobile",
    "slug": "isolvus-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050d1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#050d1a"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE"
      ],
      "package": "br.com.isolvus.mobile"
    },
    "ios": {
      "infoPlist": {
        "UIBackgroundModes": [
          "location"
        ]
      },
      "bundleIdentifier": "br.com.isolvus.mobile"
    },
    "plugins": [
      "expo-asset",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permita o acesso a localizacao para monitoramento durante o uso do app.",
          "locationAlwaysAndWhenInUsePermission": "Permita localizacao em segundo plano para monitoramento continuo.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b0410aa7-8c8d-4839-87c4-3628bc9ec200"
      }
    }
  }
}
