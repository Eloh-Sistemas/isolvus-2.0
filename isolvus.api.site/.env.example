# Banco de dados Oracle (somente)
DB_USER=
DB_PASSWORD=
# Formato: host:porta/service_name (ex.: 192.168.0.4:1521/XE)
DB_CONNECT=

# Caminho do Oracle Instant Client (obrigatório no Windows)
# Exemplo: C:\oracle\instantclient_21_9
ORACLE_CLIENT_DIR=

# API de IA (DeepSeek)
DEEPSEEK_API_KEY=

# Autenticação interna entre APIs
AUTH_API_USERNAME=
AUTH_API_PASSWORD=

# Flyway no startup da API
# Comando do binário Flyway no host (padrão: flyway)
FLYWAY_CMD=flyway
# Em emergência, permite subir API sem migration (padrão: false)
ALLOW_START_WITHOUT_MIGRATIONS=false
